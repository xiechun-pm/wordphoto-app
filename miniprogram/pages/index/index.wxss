/**
 * 首页样式
 */

/* 页面容器 */
.page-container {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  min-height: 100vh;
  padding: 40rpx;
  box-sizing: border-box;
}

/* Logo / 标题区域 */
.header-area {
  text-align: center;
  margin-bottom: 100rpx;
}

.app-title {
  font-size: 48rpx;
  font-weight: 700;
  color: #333;
  margin-bottom: 16rpx;
}

.app-subtitle {
  font-size: 28rpx;
  color: #999;
  line-height: 1.5;
}

/* 按钮容器 */
.button-group {
  display: flex;
  flex-direction: column;
  gap: 32rpx;
  width: 100%;
  max-width: 500rpx;
}

/* 功能按钮 */
.action-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 100%;
  height: 100rpx;
  border-radius: 16rpx;
  font-size: 32rpx;
  font-weight: 500;
  border: none;
  color: #fff;
}

.action-btn-primary {
  background: linear-gradient(135deg, #4facfe 0%, #00f2fe 100%);
  box-shadow: 0 8rpx 24rpx rgba(79, 172, 254, 0.3);
}

.action-btn-secondary {
  background: linear-gradient(135deg, #43e97b 0%, #38f9d7 100%);
  box-shadow: 0 8rpx 24rpx rgba(67, 233, 123, 0.3);
}

.action-btn:active {
  opacity: 0.85;
  transform: scale(0.98);
}

/* 按钮图标 */
.btn-icon {
  width: 40rpx;
  height: 40rpx;
  margin-right: 16rpx;
}

/* 底部信息 */
.footer-info {
  position: fixed;
  bottom: 60rpx;
  text-align: center;
  color: #ccc;
  font-size: 24rpx;
}