/**
 * 识别结果页样式
 */

/* 加载状态 */
.loading-container {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  min-height: 80vh;
}

.loading-text {
  margin-top: 32rpx;
  font-size: 28rpx;
  color: #999;
}

/* 错误状态 */
.error-container {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  min-height: 80vh;
  padding: 40rpx;
}

.error-icon {
  font-size: 80rpx;
  margin-bottom: 32rpx;
}

.error-text {
  font-size: 28rpx;
  color: #666;
  text-align: center;
  margin-bottom: 40rpx;
  line-height: 1.6;
}

.retry-btn {
  width: 300rpx;
  height: 80rpx;
  line-height: 80rpx;
  border-radius: 40rpx;
  background: #4facfe;
  color: #fff;
  font-size: 28rpx;
  text-align: center;
}

/* 演示模式提示条 */
.demo-notice {
  padding: 16rpx 28rpx;
  background: #fff3cd;
  border-bottom: 2rpx solid #ffc107;
  font-size: 22rpx;
  color: #856404;
  line-height: 1.5;
  text-align: center;
}

/* 结果列表区域 */
.result-container {
  display: flex;
  flex-direction: column;
  height: 100vh;
}

/* 工具栏 */
.toolbar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx 30rpx;
  background: #fff;
  border-bottom: 1rpx solid #eee;
}

.toolbar-left {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.select-all-checkbox {
  margin-right: 8rpx;
}

.toolbar-right {
  display: flex;
  gap: 20rpx;
}

.toolbar-btn {
  font-size: 26rpx;
  color: #4facfe;
  padding: 8rpx 16rpx;
}

/* 单词列表 - scroll-view 区域 */
.word-scroll {
  flex: 1;
  overflow-y: auto;
  padding: 16rpx 24rpx;
}

/* 单词卡片 */
.word-card {
  display: flex;
  align-items: center;
  background: #fff;
  border-radius: 12rpx;
  padding: 24rpx 20rpx;
  margin-bottom: 16rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
}

.word-checkbox {
  margin-right: 16rpx;
  flex-shrink: 0;
}

.word-content {
  flex: 1;
  min-width: 0;
}

.word-text {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
}

.word-meaning {
  font-size: 26rpx;
  color: #999;
  margin-top: 8rpx;
  line-height: 1.4;
}

.word-actions {
  display: flex;
  gap: 12rpx;
  flex-shrink: 0;
  margin-left: 16rpx;
}

.word-action-btn {
  font-size: 24rpx;
  color: #4facfe;
  padding: 6rpx 12rpx;
  border: 1rpx solid #4facfe;
  border-radius: 8rpx;
}

.word-action-btn-danger {
  color: #ff6b6b;
  border-color: #ff6b6b;
}

/* 底部导出按钮 */
.bottom-bar {
  padding: 20rpx 30rpx;
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
  background: #fff;
  border-top: 1rpx solid #eee;
}

.export-btn {
  width: 100%;
  height: 90rpx;
  line-height: 90rpx;
  border-radius: 16rpx;
  background: linear-gradient(135deg, #4facfe 0%, #00f2fe 100%);
  color: #fff;
  font-size: 32rpx;
  font-weight: 500;
  text-align: center;
}

.export-btn:active {
  opacity: 0.85;
}

/* 选中计数 */
.selected-count {
  font-size: 24rpx;
  color: #999;
}