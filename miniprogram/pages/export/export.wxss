/**
 * 导出页样式
 */

/* 页面容器 */
.page-container {
  min-height: 100vh;
  padding: 24rpx;
  box-sizing: border-box;
}

/* 提示文字 */
.section-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 20rpx;
}

/* 格式卡片列表 */
.format-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

/* 单个格式卡片 */
.format-card {
  display: flex;
  align-items: center;
  background: #fff;
  border-radius: 16rpx;
  padding: 28rpx 24rpx;
  border: 2rpx solid transparent;
  transition: all 0.2s;
}

.format-card.selected {
  border-color: #4facfe;
  background: #f0f9ff;
  box-shadow: 0 4rpx 16rpx rgba(79, 172, 254, 0.15);
}

.format-icon {
  font-size: 48rpx;
  margin-right: 20rpx;
  flex-shrink: 0;
}

.format-info {
  flex: 1;
  min-width: 0;
}

.format-name {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
}

.format-desc {
  font-size: 24rpx;
  color: #999;
  margin-top: 6rpx;
}

.format-check {
  width: 36rpx;
  height: 36rpx;
  border-radius: 50%;
  border: 2rpx solid #ddd;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.format-card.selected .format-check {
  background: #4facfe;
  border-color: #4facfe;
}

.format-check-inner {
  color: #fff;
  font-size: 24rpx;
  font-weight: bold;
}

/* 底部确认导出按钮 */
.bottom-area {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 20rpx 30rpx;
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
  background: #fff;
  border-top: 1rpx solid #eee;
}

.confirm-btn {
  width: 100%;
  height: 90rpx;
  line-height: 90rpx;
  border-radius: 16rpx;
  background: linear-gradient(135deg, #4facfe 0%, #00f2fe 100%);
  color: #fff;
  font-size: 32rpx;
  font-weight: 500;
  text-align: center;
}

.confirm-btn:active {
  opacity: 0.85;
}

.confirm-btn.disabled {
  background: #ccc;
  pointer-events: none;
}

/* 单词计数提示 */
.word-count {
  font-size: 24rpx;
  color: #999;
  margin-top: 12rpx;
  text-align: center;
}